# =============================================================================
# OpenClaw VPS — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   chmod 600 .env
#
# Or run ./setup.sh for an interactive guided setup.
#
# NEVER commit .env to git — it is in .gitignore.
# =============================================================================


# =============================================================================
# OPENCLAW GATEWAY
# =============================================================================

# Token required to access the Control UI dashboard.
# Set a strong passphrase. If left empty, OpenClaw will auto-generate one
# and print it to the logs on first start.
OPENCLAW_GATEWAY_TOKEN=

# Node compile cache — speeds up startup on repeated runs
NODE_COMPILE_CACHE=/var/tmp/openclaw-compile-cache


# =============================================================================
# LLM PROVIDERS — fill in the keys for the models you want to use
# =============================================================================

# Anthropic (Claude)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Groq (fast inference for open models)
# Get your key at: https://console.groq.com/
GROQ_API_KEY=

# Google Gemini
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# OpenAI (GPT-4o, o1, etc.)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenRouter — aggregates 100+ models via a single key
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Mistral AI
# Get your key at: https://console.mistral.ai/
MISTRAL_API_KEY=

# Cohere
# Get your key at: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# Together AI
# Get your key at: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# Ollama (local models — no API key, just the URL to your Ollama instance)
# If running Ollama on the same VPS: http://host.docker.internal:11434
# If running on a different machine: http://<ip>:11434
OLLAMA_BASE_URL=


# =============================================================================
# CHANNELS — messaging integrations
# =============================================================================

# Telegram (enabled by default in gateway.yml.template)
# Create a bot via @BotFather on Telegram, then paste the token here.
# Format: 123456789:ABCdef...
TELEGRAM_BOT_TOKEN=

# Discord (disabled by default — uncomment in gateway.yml.template to enable)
# Create a bot at: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# Slack (disabled by default — uncomment in gateway.yml.template to enable)
# Create a Slack app with Socket Mode at: https://api.slack.com/apps
# Requires both an App Token (xapp-...) and a Bot Token (xoxb-...)
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=

# WhatsApp — no token needed. Uses QR code login.
# After the gateway is running, authenticate with:
#   docker compose run --rm openclaw-cli channels login --channel whatsapp
